# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.smd
.contextlibcache

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Playwright profiles and browser data
chrome-user-data/
*.json

# IDEs
.idea/
.vscode/

# Ignore generated prompts or text outputs
*.txt
